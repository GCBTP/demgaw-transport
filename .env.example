# Supabase — Projet → Settings → API
# URL du projet et clé « anon » / « publishable » (sûre côté navigateur avec RLS).

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=

# Création des comptes chauffeurs (admin) : déployer la fonction
#   supabase/functions/admin-create-driver
# puis : supabase functions deploy admin-create-driver
# (SUPABASE_SERVICE_ROLE_KEY est injectée automatiquement sur Supabase.)

# Optionnel — uniquement pour `npm run db:run` (mot de passe Database, jamais dans le bundle Vite)
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=votre_ref_projet
# SUPABASE_DATABASE_URL=postgresql://postgres:...@db....supabase.co:5432/postgres
